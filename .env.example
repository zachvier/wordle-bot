# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Discord bot token — from Discord Developer Portal > Bot > Reset Token
DISCORD_TOKEN=your-discord-bot-token-here

# Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Comma-separated list of Discord channel IDs to monitor for Wordle results.
# To find a channel ID: Discord > Settings > Advanced > enable Developer Mode,
# then right-click any channel > Copy Channel ID.
# Example: WORDLE_CHANNEL_IDS=111122223333444455,666677778888999900
WORDLE_CHANNEL_IDS=your-channel-id-here

# Channel ID where the nightly reminder is sent (usually the same as your main channel).
REMINDER_CHANNEL_ID=your-channel-id-here

# Discord display name of the bot admin (case-insensitive substring match).
# This user can run privileged commands like "Wordle Forget: all".
ADMIN_USERNAME=your-admin-display-name-here

# Secret command to dump the current system prompt in Discord (not listed in Wordle Help).
# Keep this obscure. Anyone who sends this exact string in a monitored channel will
# trigger it — but only if their display name contains ADMIN_USERNAME.
ADMIN_SECRET_CMD=SysPromptWH
